# ── App ──────────────────────────────────────────────────────────────
PROJECT_NAME=Unity GSmart API
ENVIRONMENT=development
DEBUG=false

# ── Database (PostgreSQL) ─────────────────────────────────────────────
# Variable leída por connection.py (async/asyncpg) y models/base.py (sync/psycopg2).
# Para Neon u otros proveedores con SSL: agregar ?sslmode=require.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Security / JWT ───────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Game data APIs (pre-scraper Phase 0) ─────────────────────────────
# IGDB: create app at https://dev.twitch.tv/console (category: Application Integration)
IGDB_CLIENT_ID=your-twitch-client-id
IGDB_CLIENT_SECRET=your-twitch-client-secret
# RAWG: register at https://rawg.io/apidocs
RAWG_API_KEY=your-rawg-api-key

# ── Frontend / CORS ───────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=["http://localhost:5173","https://yourdomain.com"]

# ── OAuth SSO (opcional) ──────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=
# OKTA_DOMAIN=
