# DB conection variables 

# ── App ──────────────────────────────────────────────────────────────
PROJECT_NAME=Unity GSmart API
ENVIRONMENT=development

# ── Database (PostgreSQL) ───────────────────────────────────────────
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=getsmarth
POSTGRES_PORT=5432

# ── Pool ─────────────────────────────────────────────────────────────
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# POSTGRESQL URL para conexión directa (sin ORM). Driver síncrono psycopg v3.
POSTGREST_URL=postgresql://your_postgres_user:your_postgres_password@your-host.neon.tech/getsmarth?sslmode=require&channel_binding=require
DEBUG=true

# ── Security / JWT ───────────────────────────────────────────────────
# SECRET_KEY=your_secret_key_here_change_in_production_123456789
# ALGORITHM=
# ACCESS_TOKEN_EXPIRE_MINUTES=
# REFRESH_TOKEN_EXPIRE_MINUTES=

# ── Identity rules ───────────────────────────────────────────────────
# Lista separada por coma. Vacío = se acepta cualquier dominio (no recomendado en prod).
# ALLOWED_EMAIL_DOMAINS=["unitynexus.com","globant.com"]

# # ── Bootstrap del primer admin (lo consume la migración de seed) ─────
# INITIAL_ADMIN_EMAIL=admin@unitynexus.com
# INITIAL_ADMIN_PASSWORD=Admin123Change!
# INITIAL_ADMIN_FULL_NAME=Platform Admin

# # ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://9b26lkv9-5173.use2.devtunnels.ms"]

# #AI API KEYS
# GEMINI_API_KEY=
# TAVILY_API_KEY=
